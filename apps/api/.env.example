# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/3dwall

# LLM Configuration
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=

# Embedding Configuration
EMBEDDING_PROVIDER=mock
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Image Generation Configuration
IMAGE_PROVIDER=mock
IMAGE_API_KEY=

# Storage
STORAGE_PATH=./storage

# Security
API_KEY=dev-api-key-change-in-production
SECRET_KEY=dev-secret-key-change-in-production

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# App
APP_NAME=3D Wall API
APP_VERSION=0.1.0
DEBUG=true

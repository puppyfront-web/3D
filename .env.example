# ═══════════════════════════════════════════════════════════════
# 3D Wall AI 环境变量配置
# 复制此文件为 .env 并修改配置值
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── 生产必需（必填）──────────────────────────────────────────
# 生成方式: openssl rand -hex 32
POSTGRES_PASSWORD=
API_KEY=
SECRET_KEY=

# ─── 应用配置 ──────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
DOMAIN=localhost

# ─── API 服务 ──────────────────────────────────────────────────
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=https://3d.puppyfront.com,http://localhost:3000

# ─── 前端 ──────────────────────────────────────────────────────
WEB_PORT=3000
# 前端请求的后端 API 根地址（构建时注入前端 bundle；接口路径已含 /api/v1，此处只填域名根，勿加 /api，否则会变成 /api/api/v1）
# 生产环境(默认): https://3d.puppyfront.com   （API 经反向代理挂在同域 /api 下，同源请求无 CORS 问题）
# 本地开发:       http://localhost:8000
NEXT_PUBLIC_API_URL=https://3d.puppyfront.com
NEXT_PUBLIC_USE_MOCK=false

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@db:5432/3dwall

# ─── LLM Provider ─────────────────────────────────────────────
# provider: mock | openai
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o

# ─── Embedding Provider ────────────────────────────────────────
# provider: mock | openai
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Image Generation Provider ────────────────────────────────
# provider: mock | openai | dalle | siliconflow | zhipu | custom
IMAGE_PROVIDER=openai
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_MODEL=dall-e-3

# ─── Storage ──────────────────────────────────────────────────
STORAGE_PATH=./storage

# ─── Docker 镜像加速（可选，国内服务器推荐）─────────────────────
# 仅由 scripts/setup-docker-mirror.sh 读取，不参与容器运行
# 取地址：阿里云控制台 → 容器镜像服务 → 镜像工具 → 镜像加速器
# DOCKER_MIRROR=https://oj569bok.mirror.aliyuncs.com

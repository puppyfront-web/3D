# ═══════════════════════════════════════════════════════════════
# 3D Wall AI 环境变量配置
# 复制此文件为 .env 并修改配置值
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── 生产必需（必填）──────────────────────────────────────────
# 生成方式: openssl rand -hex 32
POSTGRES_PASSWORD=
API_KEY=
SECRET_KEY=

# ─── 应用配置 ──────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
DOMAIN=localhost

# ─── API 服务 ──────────────────────────────────────────────────
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000

# ─── 前端 ──────────────────────────────────────────────────────
WEB_PORT=3000
# 生产环境改为实际域名: https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCK=false

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@db:5432/3dwall

# ─── LLM Provider ─────────────────────────────────────────────
# provider: mock | openai
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o

# ─── Embedding Provider ────────────────────────────────────────
# provider: mock | openai
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Image Generation Provider ────────────────────────────────
# provider: mock | openai | dalle | siliconflow | zhipu | custom
IMAGE_PROVIDER=openai
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_MODEL=dall-e-3

# ─── Storage ──────────────────────────────────────────────────
STORAGE_PATH=./storage
